PORT=3000
NODE_ENV=development

# MongoDB connection string (Atlas M0 free tier or DO Managed MongoDB).
# Must be a replica set URL — Atlas provides this automatically.
DATABASE_URL="mongodb+srv://username:password@cluster.xxxxx.mongodb.net/chatify?retryWrites=true&w=majority"

# JWT secrets — generate with: openssl rand -hex 32
ACCESS_TOKEN_SECRET="generate-a-random-secure-string-at-least-32-characters"
REFRESH_TOKEN_SECRET="generate-a-random-secure-string-at-least-32-characters"

# Comma-separated allowed origins for CORS in production
# e.g. https://your-webapp.vercel.app,https://api.yourdomain.com
CORS_ORIGIN="http://localhost:3000,http://localhost:8081"

# Push notifications (optional)
EXPO_ACCESS_TOKEN=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_CONTACT_EMAIL=""
